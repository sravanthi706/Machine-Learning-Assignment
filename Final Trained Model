        "# ==============================\n",
        "# 4. ADVANCED MANUAL TESTING\n",
        "# ==============================\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "def predict_review(text, model):\n",
        "    # Preprocess\n",
        "    clean_text = preprocess(text)\n",
        "    vec = tfidf.transform([clean_text])\n",
        "\n",
        "    # Prediction\n",
        "    pred = model.predict(vec)[0]\n",
        "\n",
        "    # Confidence calculation\n",
        "    if hasattr(model, \"predict_proba\"):\n",
        "        prob = model.predict_proba(vec)[0]\n",
        "        confidence = np.max(prob)\n",
        "    else:\n",
        "        # For SVM (no probability)\n",
        "        decision = model.decision_function(vec)[0]\n",
        "        confidence = abs(decision) / (abs(decision) + 1)\n",
        "\n",
        "    sentiment = \"Positive 😊\" if pred == 1 else \"Negative 😞\"\n",
        "\n",
        "    return sentiment, round(confidence, 3)\n",
        "\n",
        "\n",
        "# ------------------------------\n",
        "# Choose Best Model\n",
        "# ------------------------------\n",
        "best_model = models[\"SVM\"]   # or Logistic Regression\n",
        "\n",
        "\n",
        "# ------------------------------\n",
        "# Multiple Test Cases (Advanced)\n",
        "# ------------------------------\n",
        "test_reviews = [\n",
        "    \"This movie was absolutely amazing!\",\n",
        "    \"Worst movie I have ever seen\",\n",
        "    \"The plot was interesting but execution was poor\",\n",
        "    \"I really loved the acting and direction\",\n",
        "    \"Not good, not bad, just average\"\n",
        "]\n",
        "\n",
        "results = []\n",
        "\n",
        "for review in test_reviews:\n",
        "    sentiment, confidence = predict_review(review, best_model)\n",
        "    results.append([review, sentiment, confidence])\n",
        "\n",
        "# Convert to DataFrame for clean output\n",
        "test_df = pd.DataFrame(results, columns=[\"Review\", \"Prediction\", \"Confidence\"])\n",
        "\n",
        "print(\"\\nManual Testing Results:\\n\")\n",
        "print(test_df)\n",
        "\n",
        "\n",
        "# ------------------------------\n",
        "# Single Custom Input\n",
        "# ------------------------------\n",
        "user_input = input(\"\\nEnter your own review: \")\n",
        "sentiment, confidence = predict_review(user_input, best_model)\n",
        "\n",
        "print(f\"\\nPrediction: {sentiment}\")\n",
        "print(f\"Confidence Score: {confidence}\")"
